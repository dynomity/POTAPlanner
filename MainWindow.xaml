<Window x:Class="POTAPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        Title="POTA Planner by VA6DM"
        Height="760"
        Width="1400"
        MinHeight="560"
        MinWidth="1050">

    <DockPanel Margin="10">

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Name="StatusText" Text="No parks loaded"/>
            </StatusBarItem>
        </StatusBar>

        <StackPanel DockPanel.Dock="Top">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Name="OpenButton"
                        Grid.Column="0"
                        Width="120"
                        Height="34"
                        ToolTip="Open a POTA park CSV file for viewing."
                        Click="OpenButton_Click">Open CSV</Button>

                <Button Name="UpdateDataButton"
                        Grid.Column="2"
                        Width="150"
                        Height="34"
                        ToolTip="Replace the local Canada park data with a POTA CSV you select."
                        Click="UpdateDataButton_Click">Update from CSV</Button>

                <Button Name="UpdateFromPotaButton"
                        Grid.Column="4"
                        Width="145"
                        Height="34"
                        ToolTip="Download the latest Canadian park list and activation counts from POTA."
                        Click="UpdateFromPotaButton_Click">Update from POTA</Button>

                <Button Name="ExportButton"
                        Grid.Column="6"
                        Width="120"
                        Height="34"
                        ToolTip="Export the current park view, or the planned route, to an Excel workbook."
                        Click="ExportButton_Click">Export Excel</Button>

                <TextBlock Grid.Column="8"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Text="Search:"/>

                <TextBox Grid.Column="9"
                         Name="SearchBox"
                         Margin="10,0,0,0"
                         Height="30"
                         VerticalContentAlignment="Center"
                         ToolTip="Search by park name, POTA reference, or grid square."
                         TextChanged="SearchBox_TextChanged"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Name="AllButton" Width="120" Margin="0,0,10,0" Click="AllButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="DodgerBlue" Margin="0,0,6,0"/>
                        <TextBlock Text="All Parks"/>
                    </StackPanel>
                </Button>
                <primitives:ToggleButton Name="NeverButton" Width="140" Margin="0,0,10,0" Click="NeverButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="ForestGreen" Margin="0,0,6,0"/>
                        <TextBlock Text="Never Activated"/>
                    </StackPanel>
                </primitives:ToggleButton>
                <Button Name="ProvinceButton" Width="175" Margin="0,0,10,0" Click="ProvinceButton_Click">Provinces: All Canada</Button>
                <primitives:ToggleButton Name="RareButton" Width="120" Margin="0,0,10,0" Click="RareButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="Goldenrod" Margin="0,0,6,0"/>
                        <TextBlock Text="Rare (≤5)"/>
                    </StackPanel>
                </primitives:ToggleButton>
                <Button Name="ZoomAllButton" Width="150" Margin="20,0,0,0" Click="ZoomAllButton_Click">Zoom to All Parks</Button>
                <Button Name="AboutButton" Width="80" Margin="20,0,0,0" Click="AboutButton_Click">About</Button>

                <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center" ToolTip="Green: Never Activated filter. Yellow: Rare filter. Blue: normal park or planned route stop. Gray: off-route park. Red: selected park.">
                    <Ellipse Width="9" Height="9" Fill="ForestGreen" Margin="0,0,3,0"/>
                    <TextBlock FontSize="11" Margin="0,0,8,0" Text="never"/>
                    <Ellipse Width="9" Height="9" Fill="Goldenrod" Margin="0,0,3,0"/>
                    <TextBlock FontSize="11" Margin="0,0,8,0" Text="rare"/>
                    <Ellipse Width="9" Height="9" Fill="DodgerBlue" Margin="0,0,3,0"/>
                    <TextBlock FontSize="11" Margin="0,0,8,0" Text="all/planned"/>
                    <Ellipse Width="9" Height="9" Fill="Gray" Margin="0,0,3,0"/>
                    <TextBlock FontSize="11" Margin="0,0,8,0" Text="off route"/>
                    <Ellipse Width="9" Height="9" Fill="Red" Margin="0,0,3,0"/>
                    <TextBlock FontSize="11" Text="selected"/>
                </StackPanel>

                <Popup Name="ProvincePopup"
                       PlacementTarget="{Binding ElementName=ProvinceButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Padding="10" Background="White" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
                        <StackPanel Width="245">
                            <TextBlock FontWeight="Bold" Text="Show provinces"/>
                            <TextBlock Margin="0,3,0,8" TextWrapping="Wrap" Text="Select one or more provinces, or reset to show all Canada."/>
                            <Button HorizontalAlignment="Left" Padding="10,3" Margin="0,0,0,8" Click="AllProvincesButton_Click">All Canada</Button>
                            <ListBox Name="ProvinceListBox"
                                     Height="245"
                                     SelectionMode="Multiple"
                                     SelectionChanged="ProvinceListBox_SelectionChanged"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Start:"/>
                <TextBox Name="RouteStartBox" Grid.Column="1" Margin="8,0,0,0" Height="30" VerticalContentAlignment="Center" Text="Calgary, Alberta"/>
                <TextBlock Grid.Column="3" VerticalAlignment="Center" FontWeight="Bold" Text="Destination:"/>
                <TextBox Name="RouteDestinationBox" Grid.Column="4" Margin="8,0,0,0" Height="30" VerticalContentAlignment="Center" Text="Regina, Saskatchewan"/>
                <TextBlock Grid.Column="6" VerticalAlignment="Center" FontWeight="Bold" Text="Route corridor (km):"/>
                <TextBox Name="RouteCorridorBox" Grid.Column="7" Margin="8,0,0,0" Height="30" VerticalContentAlignment="Center" Text="25"/>
                <Button Name="PlanRouteButton" Grid.Column="9" Width="105" Height="30" Click="PlanRouteButton_Click">Plan Route</Button>
                <Button Name="ClearRouteButton" Grid.Column="11" Width="90" Height="30" Click="ClearRouteButton_Click">Clear Route</Button>
            </Grid>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="250"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="3*" MinWidth="300"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="280" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4">
                <mapsui:MapControl Name="ParkMap"/>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Background="LightGray"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="150"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="2*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <DataGrid Name="ParksGrid"
                          Grid.Row="0"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          SelectionChanged="ParksGrid_SelectionChanged"
                          MouseDoubleClick="ParksGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="110"/>
                        <DataGridTextColumn Header="Park Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Grid" Binding="{Binding Grid}" Width="90"/>
                        <DataGridTextColumn Header="Activations" Binding="{Binding Activations}" Width="95"/>
                        <DataGridTextColumn Header="QSOs" Binding="{Binding QSOs}" Width="90"/>
                        <DataGridTextColumn Header="Attempts" Binding="{Binding Attempts}" Width="90"/>
                        <DataGridTextColumn Header="Latitude" Binding="{Binding Latitude,StringFormat=F5}" Width="110"/>
                        <DataGridTextColumn Header="Longitude" Binding="{Binding Longitude,StringFormat=F5}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>

                <GridSplitter Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              Background="LightGray"/>

                <GroupBox Name="RouteStopsGroup" Grid.Row="2" Header="Route Stops (0)" Padding="5">
                    <DataGrid Name="RouteStopsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionChanged="RouteStopsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="100"/>
                            <DataGridTextColumn Header="Park" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Activations" Binding="{Binding Activations}" Width="85"/>
                            <DataGridTextColumn Header="From Start" Binding="{Binding DistanceFromStart}" Width="95"/>
                            <DataGridTextColumn Header="To Destination" Binding="{Binding DistanceToDestination}" Width="105"/>
                            <DataGridTextColumn Header="From Route" Binding="{Binding DistanceFromRoute}" Width="95"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Background="LightGray"/>

            <Border Grid.Column="4"
                    Padding="15"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    CornerRadius="4">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Text="Park Details"/>

                    <TextBlock FontWeight="Bold" Text="Reference"/>
                    <TextBlock Name="ReferenceDetail" Margin="0,0,0,10" Text="—"/>

                    <TextBlock FontWeight="Bold" Text="Name"/>
                    <TextBlock Name="NameDetail" Margin="0,0,0,10" Text="—" TextWrapping="Wrap"/>

                    <TextBlock FontWeight="Bold" Text="Grid"/>
                    <TextBlock Name="GridDetail" Margin="0,0,0,10" Text="—"/>

                    <TextBlock FontWeight="Bold" Text="Activations"/>
                    <TextBlock Name="ActivationsDetail" Margin="0,0,0,10" Text="—"/>

                    <TextBlock FontWeight="Bold" Text="QSOs"/>
                    <TextBlock Name="QsosDetail" Margin="0,0,0,10" Text="—"/>

                    <TextBlock FontWeight="Bold" Text="Attempts"/>
                    <TextBlock Name="AttemptsDetail" Margin="0,0,0,10" Text="—"/>

                    <TextBlock FontWeight="Bold" Text="Latitude"/>
                    <TextBlock Name="LatitudeDetail" Margin="0,0,0,10" Text="—"/>

                    <TextBlock FontWeight="Bold" Text="Longitude"/>
                    <TextBlock Name="LongitudeDetail" Margin="0,0,0,15" Text="—"/>

                    <Button Name="GoogleMapsButton"
                            Height="34"
                            Margin="0,0,0,8"
                            IsEnabled="False"
                            Click="GoogleMapsButton_Click">Google Maps</Button>

                    <Button Name="AddToRouteButton"
                            Height="34"
                            IsEnabled="False"
                            Click="AddToRouteButton_Click">Add to Route</Button>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
