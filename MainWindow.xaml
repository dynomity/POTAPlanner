<Window x:Class="POTAPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POTA Planner"
        Height="700"
        Width="1100"
        MinHeight="500"
        MinWidth="900">

    <DockPanel Margin="10">

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Name="StatusText"
                           Text="No parks loaded"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Top Controls -->
        <StackPanel DockPanel.Dock="Top">

            <Grid Margin="0,0,0,10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Name="OpenButton"
            Grid.Column="0"
            Width="120"
            Height="34"
            Click="OpenButton_Click">
                    Open CSV
                </Button>

                <Button Name="ExportButton"
            Grid.Column="2"
            Width="120"
            Height="34"
            Click="ExportButton_Click">
                    Export Excel
                </Button>

                <TextBlock Grid.Column="4"
               VerticalAlignment="Center"
               FontWeight="Bold"
               Text="Search:"/>

                <TextBox Grid.Column="5"
             Name="SearchBox"
             Margin="10,0,0,0"
             Height="30"
             VerticalContentAlignment="Center"
             TextChanged="SearchBox_TextChanged"/>

            </Grid>

        </StackPanel>

        <!-- Main Grid -->

        <DataGrid Name="ParksGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  MouseDoubleClick="ParksGrid_MouseDoubleClick">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="Reference"
                    Binding="{Binding Reference}"
                    Width="110"/>

                <DataGridTextColumn
                    Header="Park Name"
                    Binding="{Binding Name}"
                    Width="*"/>

                <DataGridTextColumn
                    Header="Grid"
                    Binding="{Binding Grid}"
                    Width="90"/>

                <DataGridTextColumn
                    Header="Activations"
                    Binding="{Binding Activations}"
                    Width="95"/>

                <DataGridTextColumn
                    Header="QSOs"
                    Binding="{Binding QSOs}"
                    Width="90"/>

                <DataGridTextColumn
                    Header="Attempts"
                    Binding="{Binding Attempts}"
                    Width="90"/>

                <DataGridTextColumn
                    Header="Latitude"
                    Binding="{Binding Latitude,StringFormat=F5}"
                    Width="110"/>

                <DataGridTextColumn
                    Header="Longitude"
                    Binding="{Binding Longitude,StringFormat=F5}"
                    Width="110"/>

            </DataGrid.Columns>

        </DataGrid>

    </DockPanel>

</Window>